# ============================================================
# 专业课程答疑系统 - 环境变量配置模板
# 
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改 .env 文件中的配置值
# 3. 在启动应用前加载环境变量：source .env (Linux/Mac) 或在 Docker 中使用
# ============================================================

# ============================================================
# API 密钥配置（必需）
# ============================================================

# DeepSeek LLM API 密钥
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云百炼 Embedding API 密钥
BAILIAN_API_KEY=sk-your-bailian-api-key-here

# ============================================================
# 企业级增强配置（可选）
# ============================================================

# Redis 配置（如果使用分布式缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# JWT 认证配置（如果启用 JWT 认证）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# 密钥管理器主密钥（如果启用密钥管理）
SECRET_MASTER_KEY=your-master-key-for-encrypting-secrets

# ============================================================
# 服务配置
# ============================================================

# 服务端口
PORT=5000

# 服务主机
HOST=127.0.0.1

# 配置文件路径
QA_CONFIG=config.yaml

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================
# CORS 配置
# ============================================================

# 允许的源（逗号分隔，* 表示允许所有）
CORS_ORIGINS=*

# 允许的 Origin（用于 CSRF 保护）
ALLOWED_ORIGINS=

# ============================================================
# HuggingFace 镜像配置（中国大陆用户）
# ============================================================

# HuggingFace 镜像端点
HF_ENDPOINT=https://hf-mirror.com

# 离线模式（1=启用，0=禁用）
HF_HUB_OFFLINE=1

# ============================================================
# 监控配置（可选）
# ============================================================

# Prometheus 指标端点
METRICS_ENABLED=true

# 告警 Webhook URL（如果使用 Webhook 告警）
ALERT_WEBHOOK_URL=

# ============================================================
# 安全配置
# ============================================================

# 启用 HTTPS（生产环境推荐）
HTTPS_ENABLED=false

# SSL 证书路径
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================================
# 性能配置
# ============================================================

# Gunicorn worker 数量（默认：CPU 核心数 * 2 + 1）
GUNICORN_WORKERS=4

# Gunicorn 超时时间（秒）
GUNICORN_TIMEOUT=120

# 最大并发请求数
MAX_CONCURRENT_REQUESTS=100
